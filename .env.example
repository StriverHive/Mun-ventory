# Copy this file to ".env" for local dev, or set these as Environment Variables
# in the Render dashboard when hosting. NEVER commit the real .env (it is git-ignored).

# MongoDB Atlas connection string (Database > Connect > Drivers).
# The standard (mongodb://...) form works everywhere; the mongodb+srv://... form
# also works on Render.
MONGODB_URI=your-mongodb-connection-string

# The PIN that unlocks the app.
APP_PIN=2026

# Any long random string used to sign the login session cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Local dev only. On Render this is set automatically — do NOT add it there.
PORT=3000

# Set to 0 ONLY if you run Node directly exposed to the internet with no proxy.
# On Render (which puts a proxy in front) leave this unset.
# TRUST_PROXY=0
